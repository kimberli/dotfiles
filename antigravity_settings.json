{
    "editor.acceptSuggestionOnCommitCharacter": false,
    "editor.codeActionsOnSave": {
        "source.fixAll": "explicit",
        "source.fixAll.eslint": "explicit"
    },
    "editor.formatOnSave": true,
    "editor.lineNumbers": "relative",
    "editor.minimap.enabled": false,
    "editor.multiCursorModifier": "ctrlCmd",
    "editor.wordWrap": "on",
    "eslint.codeActionsOnSave.mode": "all",
    "eslint.enable": true,
    "eslint.format.enable": true,
    "eslint.run": "onSave",
    "eslint.trace.server": "verbose",
    "eslint.workingDirectories": [
        {
            "mode": "auto"
        }
    ],
    "explorer.autoReveal": false,
    "explorer.confirmDragAndDrop": false,
    "extensions.experimental.affinity": {
        "asvetliakov.vscode-neovim": 1
    },
    "html.autoClosingTags": false,
    "javascript.autoClosingTags": false,
    "terminal.integrated.defaultProfile.osx": "zsh",
    "terminal.integrated.scrollback": 10000,
    "typescript.autoClosingTags": false,
    "vscode-neovim.ctrlKeysForNormalMode": [
        "a",
        "b",
        "d",
        "e",
        "f",
        "h",
        "i",
        "j",
        "k",
        "l",
        "m",
        "o",
        "r",
        "t",
        "u",
        "v",
        "w",
        "x",
        "y",
        "z",
        "/",
        "]",
        "right",
        "left",
        "up",
        "down",
        "backspace",
        "delete"
    ],
    "workbench.colorTheme": "Default Dark Modern",
    "workbench.preferredDarkColorTheme": "Everforest Dark",
    "workbench.preferredHighContrastColorTheme": "Everforest Dark",
    "workbench.preferredHighContrastLightColorTheme": "Everforest Light",
    "workbench.preferredLightColorTheme": "Everforest Light",
    "zenMode.hideLineNumbers": false,
    "remote.autoForwardPortsSource": "hybrid",
    "terminal.integrated.macOptionClickForcesSelection": true,
    "git.openRepositoryInParentFolders": "never",
    "javascript.updateImportsOnFileMove.enabled": "always",
    "typescript.updateImportsOnFileMove.enabled": "always",
    "jest.runMode": "on-demand",
    "[typescript]": {
        "editor.defaultFormatter": "dbaeumer.vscode-eslint"
    },
    "extensions.ignoreRecommendations": true,
    "vitest.filesWatcherInclude": "**/*.{js,ts,tsx,jsx}",
    "vitest.debugExclude": [
        "<node_internals>/**",
        "**/node_modules/**"
    ],
    "files.autoSave": "afterDelay",
    "window.autoDetectColorScheme": true
}
